{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/metaamr/master/nextflow_schema.json",
    "title": "nf-core/metaamr pipeline parameters",
    "description": "MetaAMR: A Nextflow pipeline for long-read metagenomics classification and antimicrobial resistance detection",
    "type": "object",
    "$defs": {
        "input_output_options": {
            "title": "Input/output options",
            "type": "object",
            "fa_icon": "fas fa-terminal",
            "description": "Define where the pipeline should find input data and save output data.",
            "required": ["input", "outdir"],
            "properties": {
                "input": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "schema": "assets/schema_input.json",
                    "mimetype": "text/csv",
                    "pattern": "^\\S+\\.csv$",
                    "description": "Path to comma-separated file containing information about the samples in the experiment.",
                    "help_text": "You will need to create a design file with information about the samples in your experiment before running the pipeline. Use this parameter to specify its location. It has to be a comma-separated file with 3 columns, and a header row. See [usage docs](https://nf-co.re/metaamr/usage#samplesheet-input).",
                    "fa_icon": "fas fa-file-csv"
                },
                "outdir": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "The output directory where the results will be saved. You have to use absolute paths to storage on Cloud infrastructure.",
                    "fa_icon": "fas fa-folder-open"
                },
                "email": {
                    "type": "string",
                    "description": "Email address for completion summary.",
                    "fa_icon": "fas fa-envelope",
                    "help_text": "Set this parameter to your e-mail address to get a summary e-mail with details of the run sent to you when the workflow exits. If set in your user config file (`~/.nextflow/config`) then you don't need to specify this on the command line for every run.",
                    "pattern": "^([a-zA-Z0-9_\\-\\.]+)@([a-zA-Z0-9_\\-\\.]+)\\.([a-zA-Z]{2,5})$"
                },
                "multiqc_title": {
                    "type": "string",
                    "description": "MultiQC report title. Printed as page header, used for filename if not otherwise specified.",
                    "fa_icon": "fas fa-file-signature"
                }
            }
        },

        "process_options": {
            "title": "Process options",
            "type": "object",
            "description": "Nextflow process-specific options",
            "properties": {
                "process": {
                    "type": "object",
                    "description": "Nextflow process options",
                    "properties": {
                        "cache": {
                            "type": "string",
                            "default": "deep",
                           "description": "Caching mode for processes"
                        }
                    }
                }
            }
        },

        "reference_genome_options": {
            "title": "Reference genome options",
            "type": "object",
            "fa_icon": "fas fa-dna",
            "description": "Reference genome related files and options required for the workflow.",
            "properties": {
                "genome": {
                    "type": "string",
                    "description": "Name of iGenomes reference.",
                    "fa_icon": "fas fa-book",
                    "help_text": "If using a reference genome configured in the pipeline using iGenomes, use this parameter to give the ID for the reference. This is then used to build the full paths for all required reference genome files e.g. `--genome GRCh38`. \n\nSee the [nf-core website docs](https://nf-co.re/usage/reference_genomes) for more details."
                },
                "fasta": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "mimetype": "text/plain",
                    "pattern": "^\\S+\\.fn?a(sta)?(\\.gz)?$",
                    "description": "Path to FASTA genome file.",
                    "help_text": "This parameter is *mandatory* if `--genome` is not specified. If you don't have a BWA index available this will be generated for you automatically. Combine with `--save_reference` to save BWA index for future runs.",
                    "fa_icon": "far fa-file-code"
                },
                "igenomes_ignore": {
                    "type": "boolean",
                    "description": "Do not load the iGenomes reference config.",
                    "fa_icon": "fas fa-ban",
                    "hidden": true,
                    "help_text": "Do not load `igenomes.config` when running the pipeline. You may choose this option if you observe clashes between custom parameters and those supplied in `igenomes.config`."
                },
                "igenomes_base": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "The base path to the igenomes reference files",
                    "fa_icon": "fas fa-ban",
                    "hidden": true,
                    "default": "s3://ngi-igenomes/igenomes/"
                }
            }
        },
        
        "read_processing_options": {
            "title": "Read processing options",
            "type": "object",
            "fa_icon": "fas fa-dna",
            "description": "Options for read processing and quality control",
            "properties": {
                "filtlong_minlength": {
                    "type": "integer",
                    "default": 1000,
                    "description": "Minimum length of reads to keep"
                },
                "filtlong_keeppercent": {
                   "type": "integer",
                    "default": 80,
                    "description": "Percent of the best reads to keep"
                },
                "filtlong_targetbases": {
                    "type": "integer",
                    "default": 200000000,
                    "description": "Target number of bases to keep"
                },
                "save_filtered_reads": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save the filtered long reads"
                },
                "validate_params": {
                    "type": "boolean",
                    "default": true,
                    "description": "Validate parameters against the schema at runtime"
                },
                "skip_trim": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skip read trimming step"
                }
            }
        },

        "host_removal_options": {
            "title": "Host removal options",
            "type": "object",
            "fa_icon": "fas fa-filter",
            "description": "Options for host sequence removal",
            "properties": {
                "reference": {
                    "type": ["string", "null"],
                    "default": null,
                    "description": "Path to reference genome for host removal"
                },
                "perform_hostremoval": {
                    "type": "boolean",
                    "default": true,
                    "description": "Perform host sequence removal"
                },
                "hostremoval_index": {
                    "type": ["string", "null"],
                    "default": null,
                    "description": "Path to pre-built host removal index"
                },
                "hostremoval_reference": {
                    "type": ["string", "null"],
                    "default": null,
                    "description": "Path to host reference genome for removal"
                },
               "save_hostremoval_index": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save the host removal index"
                },
                "save_hostremoval_bam": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save the BAM file from host removal"
                },
                "save_hostremoval_unmapped": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save unmapped reads after host removal"
                },
                "save_analysis_ready_fastqs": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save analysis-ready FASTQs after host removal"
                }
            }
        },
        
        
        "assembly_options": {
            "title": "Assembly options",
            "type": "object",
            "fa_icon": "fas fa-puzzle-piece",
            "description": "Options for genome assembly",
            "properties": {
                "perform_assembly": {
                    "type": "boolean",
                    "default": true,
                    "description": "Perform genome assembly"
                },
                "perform_polish_assembly": {
                    "type": "boolean",
                    "default": false,
                    "description": "Perform assembly polishing"
                },
                "use_second_polish": {
                    "type": "boolean",
                    "default": true,
                    "description": "Use second round of polishing (set to false to use only the first round)"
                }
            }
        },

        "database_options": {
            "title": "Database options",
            "type": "object",
            "description": "Options for database handling",
            "properties": {
                "save_untarred_databases": {
                    "type": "boolean",
                    "default": false,
                    "description": "Save untarred databases"
                },
                "save_databases": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save databases"
                },
                "resfinder_db": {
                    "type": ["string", "null"],
                    "default": null,
                    "description": "Path to ResFinder database"
                },
                "download_resfinder_db": {
                    "type": "boolean",
                    "default": true,
                    "description": "Download ResFinder database"
                },
                "rgi_db": {
                    "type": ["string", "null"],
                    "default": null,
                    "description": "Path to RGI database"
                },
                "download_rgi_db": {
                    "type": "boolean",
                    "default": true,
                    "description": "Download RGI database"
                },
                "amrfinderplus_db": {
                    "type": ["string", "null"],
                    "default": null,
                    "description": "Path to AMRFinderPlus database"
                },
                "download_amrfinderplus_db": {
                    "type": "boolean",
                    "default": true,
                    "description": "Download AMRFinderPlus database"
                },
                "abricate_db": {
                    "type": ["string", "null"],
                    "default": null,
                    "description": "Path to Abricate database"
                },
                "plasmidfinder_db": {
                    "type": ["string", "null"],
                    "default": null,
                    "description": "Path to PlasmidFinder database"
                },
                "download_plasmidfinder_db": {
                    "type": "boolean",
                    "default": true,
                    "description": "Download PlasmidFinder database"
                }
            }
        },

        "tool_execution_options": {
            "title": "Tool execution options",
            "type": "object",
            "fa_icon": "fas fa-tools",
            "description": "Options for executing various analysis tools",
            "properties": {
                "run_resfinder": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run ResFinder for antimicrobial resistance gene detection"
                },
          
                "resfinder_args": {
                    "type": "string",
                    "default": "",
                    "description": "Additional arguments for ResFinder"
                },
                "resfinder_point_mutations": {
                    "type": "boolean",
                    "default": false,
                    "description": "Include point mutations in ResFinder analysis"
                },
                "run_rgi": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run RGI (Resistance Gene Identifier)"
                },
                "rgi_min_coverage": {
                    "type": "number",
                    "default": 0.8,
                    "description": "Minimum coverage for RGI"
                },
                "rgi_min_identity": {
                    "type": "number",
                    "default": 0.8,
                    "description": "Minimum identity for RGI"
                },
                "run_amrfinderplus": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run AMRFinderPlus"
                },
                "amrfinderplus_args": {
                    "type": "string",
                    "default": "",
                    "description": "Additional arguments for AMRFinderPlus"
                },
                "amrfinderplus_version": {
                    "type": "string",
                    "default": "unknown",
                    "description": "Version of AMRFinderPlus to use"
                },
                "run_abricate": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run Abricate"
                },
                "arg_abricate_db": {
                    "type": "string",
                    "default": "vfdb",
                    "description": "Database to use with Abricate"
                },
                "abricate_minid": {
                    "type": "integer",
                    "default": 80,
                    "description": "Minimum identity percentage for Abricate"
                },
                "abricate_mincov": {
                    "type": "integer",
                    "default": 80,
                    "description": "Minimum coverage percentage for Abricate"
                },
                "run_validate_fasta": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run FASTA validation"
                },
                "run_plasmidfinder": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run PlasmidFinder"
                },
                "plasmidfinder_args": {
                    "type": "string",
                    "default": "",
                    "description": "Additional arguments for PlasmidFinder"
                },
                "run_plasclass": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run PlasClass"
                },
                "plasclass_options": {
                    "type": "string",
                    "default": "",
                    "description": "Additional options for PlasClass"
                },
                "plasclass_threshold": {
                    "type": "number",
                    "default": 0.9,
                    "description": "Threshold for PlasClass"
                },
                "run_hamronization": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run Hamronization"
                },
                "hamronization_tools": {
                    "type": "array",
                    "default": ["abricate", "amrfinderplus", "rgi"],
                    "description": "Tools to include in Hamronization"
                },
                "arg_hamronization_format": {
                    "type": "string",
                    "default": "tsv",
                    "description": "Output format for Hamronization"
                },
                "arg_hamronization_summarizeformat": {
                    "type": "string",
                    "default": "tsv",
                    "description": "Summary format for Hamronization"
                },
                "run_hamronization_summarize": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run Hamronization summarize"
                },
                "abricate_version": {
                    "type": "string",
                    "default": "unknown",
                    "description": "Version of Abricate"
                },
                "abricate_db_version": {
                    "type": "string",
                    "default": "unknown",
                    "description": "Version of Abricate database"
                },
                
                "amrfinderplus_db_version": {
                    "type": "string",
                    "default": "unknown",
                    "description": "Version of AMRFinderPlus database"
                },
                "rgi_version": {
                    "type": "string",
                    "default": "unknown",
                    "description": "Version of RGI"
                },
                "card_version": {
                    "type": "string",
                    "default": "unknown",
                    "description": "Version of CARD database"
                }
            }
        },
        "institutional_config_options": {
            "title": "Institutional config options",
            "type": "object",
            "fa_icon": "fas fa-university",
            "description": "Parameters used to describe centralised config profiles. These should not be edited.",
            "help_text": "The centralised nf-core configuration profiles use a handful of pipeline parameters to describe themselves. This information is then printed to the Nextflow log when you run a pipeline. You should not need to change these values when you run a pipeline.",
            "properties": {
                "custom_config_version": {
                    "type": "string",
                    "description": "Git commit id for Institutional configs.",
                    "default": "master",
                    "hidden": true,
                    "fa_icon": "fas fa-users-cog"
                },
                "custom_config_base": {
                    "type": "string",
                    "description": "Base directory for Institutional configs.",
                    "default": "https://raw.githubusercontent.com/nf-core/configs/master",
                    "hidden": true,
                    "help_text": "If you're running offline, Nextflow will not be able to fetch the institutional config files from the internet. If you don't need them, then this is not a problem. If you do need them, you should download the files from the repo and tell Nextflow where to find them with this parameter.",
                    "fa_icon": "fas fa-users-cog"
                },
                "config_profile_name": {
                    "type": "string",
                    "description": "Institutional config name.",
                    "hidden": true,
                    "fa_icon": "fas fa-users-cog"
                },
                "config_profile_description": {
                    "type": "string",
                    "description": "Institutional config description.",
                    "hidden": true,
                    "fa_icon": "fas fa-users-cog"
                },
                "config_profile_contact": {
                    "type": "string",
                    "description": "Institutional config contact information.",
                    "hidden": true,
                    "fa_icon": "fas fa-users-cog"
                },
                "config_profile_url": {
                    "type": "string",
                    "description": "Institutional config URL link.",
                    "hidden": true,
                    "fa_icon": "fas fa-users-cog"
                }
            }
        },
        "generic_options": {
            "title": "Generic options",
            "type": "object",
            "fa_icon": "fas fa-file-import",
            "description": "Less common options for the pipeline, typically set in a config file.",
            "help_text": "These options are common to all nf-core pipelines and allow you to customise some of the core preferences for how the pipeline runs.\n\nTypically these options would be set in a Nextflow config file loaded for all pipeline runs, such as `~/.nextflow/config`.",
            "properties": {
                "version": {
                    "type": "boolean",
                    "description": "Display version and exit.",
                    "fa_icon": "fas fa-question-circle",
                    "hidden": true
                },
                
                "publish_dir_mode": {
                    "type": "string",
                    "default": "copy",
                    "description": "Method used to save pipeline results to output directory.",
                    "help_text": "The Nextflow `publishDir` option specifies which intermediate files should be saved to the output directory. This option tells the pipeline what method should be used to move these files. See [Nextflow docs](https://www.nextflow.io/docs/latest/process.html#publishdir) for details.",
                    "fa_icon": "fas fa-copy",
                    "enum": ["symlink", "rellink", "link", "copy", "copyNoFollow", "move"],
                    "hidden": true
                },
                "email_on_fail": {
                    "type": "string",
                    "description": "Email address for completion summary, only when pipeline fails.",
                    "fa_icon": "fas fa-exclamation-triangle",
                    "pattern": "^([a-zA-Z0-9_\\-\\.]+)@([a-zA-Z0-9_\\-\\.]+)\\.([a-zA-Z]{2,5})$",
                    "help_text": "An email address to send a summary email to when the pipeline is completed - ONLY sent if the pipeline does not exit successfully.",
                    "hidden": true
                },
                "plaintext_email": {
                    "type": "boolean",
                    "description": "Send plain-text email instead of HTML.",
                    "fa_icon": "fas fa-remove-format",
                    "hidden": true
                },
                "max_multiqc_email_size": {
                    "type": "string",
                    "description": "File size limit when attaching MultiQC reports to summary emails.",
                    "pattern": "^\\d+(\\.\\d+)?\\.?\\s*(K|M|G|T)?B$",
                    "default": "25.MB",
                    "fa_icon": "fas fa-file-upload",
                    "hidden": true
                },
                "monochrome_logs": {
                    "type": "boolean",
                    "description": "Do not use coloured log outputs.",
                    "fa_icon": "fas fa-palette",
                    "hidden": true
                },
                "hook_url": {
                    "type": "string",
                    "description": "Incoming hook URL for messaging service",
                    "fa_icon": "fas fa-people-group",
                    "help_text": "Incoming hook URL for messaging service. Currently, MS Teams and Slack are supported.",
                    "hidden": true
                },
                "multiqc_config": {
                    "type": "string",
                    "format": "file-path",
                    "description": "Custom config file to supply to MultiQC.",
                    "fa_icon": "fas fa-cog",
                    "hidden": true
                },
                "multiqc_logo": {
                    "type": "string",
                    "description": "Custom logo file to supply to MultiQC. File name must also be set in the MultiQC config file",
                    "fa_icon": "fas fa-image",
                    "hidden": true
                },
                "multiqc_methods_description": {
                    "type": "string",
                    "description": "Custom MultiQC yaml file containing HTML including a methods description.",
                    "fa_icon": "fas fa-cog"
                },
                "validate_params": {
                    "type": "boolean",
                    "description": "Boolean whether to validate parameters against the schema at runtime",
                    "default": true,
                    "fa_icon": "fas fa-check-square",
                    "hidden": true
                },
                "pipelines_testdata_base_path": {
                    "type": "string",
                    "fa_icon": "far fa-check-circle",
                    "description": "Base URL or local path to location of pipeline test dataset files",
                    "default": "https://raw.githubusercontent.com/nf-core/test-datasets/",
                    "hidden": true
                }
            }
        },
        
        "profiling_options": {
            "title": "Profiling options",
            "type": "object",
            "fa_icon": "fas fa-microbes",
            "description": "Options for taxonomic profiling tools",
            "properties": {
                "databases": {
                    "type": "string",
                    "format": "file-path",
                    "exists": true,
                    "mimetype": "text/csv",
                    "pattern": "^\\S+\\.csv$",
                    "description": "Path to CSV file containing database information for profiling tools",
                    "help_text": "Provide a CSV file with columns: tool, db_name, db_params, db_path",
                    "fa_icon": "fas fa-database"
                },
                "run_profiling": {
                    "type": "boolean",
                    "description": "Run taxonomic profiling",
                    "fa_icon": "fas fa-play",
                    "default": false
                },
                "run_kaiju": {
                    "type": "boolean",
                    "description": "Run Kaiju for taxonomic profiling",
                    "fa_icon": "fas fa-play",
                    "default": true
                },
                "run_centrifuge": {
                    "type": "boolean",
                    "description": "Run Centrifuge for taxonomic profiling",
                    "fa_icon": "fas fa-play",
                    "default": true
                },
                "save_centrifuge_unclassified": {
                    "type": "boolean",
                    "description": "Save unclassified reads from Centrifuge",
                    "fa_icon": "fas fa-save",
                    "default": false
                },
                "save_centrifuge_classified": {
                    "type": "boolean",
                    "description": "Save classified reads from Centrifuge",
                    "fa_icon": "fas fa-save",
                    "default": true
                }
            }   
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/input_output_options"
        },
        {
            "$ref": "#/$defs/reference_genome_options"
        },
        {
            "$ref": "#/$defs/institutional_config_options"
        },
        {
            "$ref": "#/$defs/generic_options"
        },
        {
            "$ref": "#/$defs/profiling_options"
        },
        {
            "$ref": "#/$defs/read_processing_options"
        },
        {
            "$ref": "#/$defs/host_removal_options"
        },
        {
            "$ref": "#/$defs/assembly_options"
        },
        {
            "$ref": "#/$defs/tool_execution_options"
        },
        {
            "$ref": "#/$defs/database_options"
        },
        {
            "$ref": "#/$defs/process_options"
        }  
        
    ]
}
